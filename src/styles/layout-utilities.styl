/**
 * Altrex Mobile-First Layout Utilities
 *
 * Responsive utility classes for common layout patterns.
 * All utilities follow mobile-first approach.
 */

// Container patterns
.altrex-container
  container-width($altrex-breakpoints-2xl)

.altrex-container--narrow
  container-width($altrex-breakpoints-md)

.altrex-container--wide
  container-width($altrex-breakpoints-xl)

// Responsive stacks (column → row)
.altrex-stack
  stack-to-row('md')

  &--to-row-sm
    stack-to-row('sm')

  &--to-row-lg
    stack-to-row('lg')

  &--to-row-xl
    stack-to-row('xl')

// Responsive grid (auto-fit pattern)
.altrex-grid
  display: grid
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr))
  gap: $altrex-spacing-4

  &--gap-2
    gap: $altrex-spacing-2

  &--gap-6
    gap: $altrex-spacing-6

  &--gap-8
    gap: $altrex-spacing-8

  // Fixed column counts at breakpoints
  &--cols-2
    +above('sm')
      grid-template-columns: repeat(2, 1fr)

  &--cols-3
    +above('md')
      grid-template-columns: repeat(3, 1fr)

  &--cols-4
    +above('lg')
      grid-template-columns: repeat(4, 1fr)

  &--cols-6
    +above('xl')
      grid-template-columns: repeat(6, 1fr)

  // Minimum column width variations
  &--min-200
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr))

  &--min-300
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr))

  &--min-400
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr))

// Visibility utilities
.altrex-hide-mobile
  display: none

  +above('md')
    display: block

.altrex-hide-tablet
  +above('md')
    display: none

  +above('lg')
    display: block

.altrex-hide-desktop
  +above('md')
    display: none

.altrex-show-mobile-only
  display: block

  +above('md')
    display: none

.altrex-show-tablet-only
  display: none

  +above('md')
    display: block

  +above('lg')
    display: none

.altrex-show-desktop-only
  display: none

  +above('lg')
    display: block

// Spacing utilities (mobile-first)
.altrex-mt-mobile
  margin-top: $altrex-spacing-4

  +above('md')
    margin-top: 0

.altrex-mb-mobile
  margin-bottom: $altrex-spacing-4

  +above('md')
    margin-bottom: 0

.altrex-mx-auto
  margin-left: auto
  margin-right: auto

// Flexbox utilities
.altrex-flex
  display: flex

  &--column
    flex-direction: column

  &--row
    flex-direction: row

  &--column-reverse
    flex-direction: column-reverse

  &--row-reverse
    flex-direction: row-reverse

  &--wrap
    flex-wrap: wrap

  &--nowrap
    flex-wrap: nowrap

  &--center
    align-items: center
    justify-content: center

  &--between
    justify-content: space-between

  &--around
    justify-content: space-around

  &--evenly
    justify-content: space-evenly

// Responsive text alignment
.altrex-text-center-mobile
  text-align: center

  +above('md')
    text-align: left

.altrex-text-center-desktop
  text-align: left

  +above('md')
    text-align: center

// Full-width on mobile
.altrex-full-width-mobile
  width: 100%

  +above('md')
    width: auto

// Responsive padding
.altrex-p-responsive
  padding: $altrex-spacing-4

  +above('md')
    padding: $altrex-spacing-6

  +above('lg')
    padding: $altrex-spacing-8

.altrex-px-responsive
  padding-left: $altrex-spacing-4
  padding-right: $altrex-spacing-4

  +above('md')
    padding-left: $altrex-spacing-6
    padding-right: $altrex-spacing-6

  +above('lg')
    padding-left: $altrex-spacing-8
    padding-right: $altrex-spacing-8

.altrex-py-responsive
  padding-top: $altrex-spacing-4
  padding-bottom: $altrex-spacing-4

  +above('md')
    padding-top: $altrex-spacing-6
    padding-bottom: $altrex-spacing-6

  +above('lg')
    padding-top: $altrex-spacing-8
    padding-bottom: $altrex-spacing-8
